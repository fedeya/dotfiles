{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "permission": {
    "*": "ask",
    "edit": "ask",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.envrc": "deny",
      "secrets/*": "deny"
    },
    "todowrite": "allow",
    "todoread": "allow",
    "codesearch": "allow",
    "websearch": "allow",
    "grep *": "allow",
    "glob": "allow",
    "lsp": "allow",
    "bash": {
      "*": "ask",
      "ast-grep *": "allow",
      "awk *": "allow",
      "basename *": "allow",
      "biome *": "allow",
      "bun *": "allow",
      "cargo *": "allow",
      "cat *": "allow",
      "cloc *": "allow",
      "cp *": "allow",
      "date *": "allow",
      "diff *": "allow",
      "dirname *": "allow",
      "dot *": "allow",
      "du *": "allow",
      "echo *": "allow",
      "fd *": "allow",
      "file *": "allow",
      "find *": "allow",
      "fnm *": "allow",
      "fzf *": "allow",
      "gh *": "allow",
      "gh * approve*": "ask",
      "gh * close*": "ask",
      "gh * comment*": "ask",
      "gh * create*": "ask",
      "gh * delete*": "ask",
      "gh * edit*": "ask",
      "gh * merge*": "ask",
      "gh * reopen*": "ask",
      "gh * review*": "ask",
      "gh repo clone*": "allow",
      "git *": "allow",
      "git push*": "ask",
      "go *": "allow",
      "grep *": "allow",
      "gsed *": "allow",
      "gunzip *": "allow",
      "gzip *": "allow",
      "head *": "allow",
      "hostname": "allow",
      "id": "allow",
      "jq *": "allow",
      "ls *": "allow",
      "make *": "allow",
      "mkdir *": "allow",
      "mv *": "allow",
      "npm *": "allow",
      "open *": "allow",
      "pbcopy": "allow",
      "pbpaste": "allow",
      "pnpm *": "allow",
      "prettier *": "allow",
      "printf *": "allow",
      "pwd": "allow",
      "readlink *": "allow",
      "realpath *": "allow",
      "rg *": "allow",
      "rtk *": "allow",
      "sed *": "allow",
      "shellcheck *": "allow",
      "sort *": "allow",
      "stat *": "allow",
      "stow *": "allow",
      "stylua *": "allow",
      "tail *": "allow",
      "tar *": "allow",
      "tee *": "allow",
      "touch *": "allow",
      "tr *": "allow",
      "tree *": "allow",
      "true": "allow",
      "tsc *": "allow",
      "turbo *": "allow",
      "uv *": "allow",
      "uname *": "allow",
      "uniq *": "allow",
      "unzip *": "allow",
      "vite *": "allow",
      "vitest *": "allow",
      "wc *": "allow",
      "which *": "allow",
      "whoami": "allow",
      "xargs *": "ask",
      "yarn *": "allow",
      "z *": "allow",
      "zip *": "allow",
      "zoxide *": "allow"
    },
    "webfetch": "allow",
    "task": "allow",
    "skill": "allow",
    "external_directory": {
      "*": "allow",
      "~/.local/share/opencode/mcp-auth.json": "deny"
    }
  },
  "plugin": [
    "@mohak34/opencode-notifier@latest"
  ],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "grep_app": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    },
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp"
    },
  },
  "lsp": {
    "ruff": {
      "command": [
        "ruff",
        "server"
      ],
      "extensions": [
        ".py"
      ]
    },
  }
}
